{
  "name": "usj-seed",
  "version": "1.0.0",
  "type": "module",
  "description": "Seed script: migrates product images + data to Supabase",
  "scripts": {
    "seed": "node seed.js",
    "seed:enter": "node seed.js --brand=enter",
    "seed:tenda": "node seed.js --brand=tenda",
    "seed:zoook": "node seed.js --brand=zoook",
    "compress-images": "node compress-images.js",
    "fix-image-urls": "node fix-image-urls.js"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "dotenv": "^16.4.5",
    "sharp": "^0.33.5"
  },
  "allowScripts": {
    "sharp@0.33.5": true
  }
}
